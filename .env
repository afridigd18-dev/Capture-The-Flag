# Flask Core
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
FLASK_ENV=development
FLASK_DEBUG=1

# Database
DATABASE_URL=sqlite:///ctf.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/ctfdb

# Admin Bootstrap
ADMIN_EMAIL=admin@ctf.local
ADMIN_PASSWORD=Admin@CTF2024!

# Rate Limiting
RATELIMIT_STORAGE_URL=memory://

# Security
WTF_CSRF_ENABLED=True
SESSION_COOKIE_SECURE=False   # Set True in production with HTTPS
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
